# Copy to .env and fill in. Never commit .env.

# Required in production.
FLASK_ENV=production
# Set automatically in the official Dockerfile; requires ZOHO_SERVICE_BASE_URL at runtime.
# TABLETTRACKER_SELF_HOSTED=1

SECRET_KEY=
ADMIN_PASSWORD=

# SQLite: default is database/tablet_counter.db. In Docker use a volume and e.g.:
# DATABASE_PATH=/data/tablet_counter.db
# DATABASE_URL=sqlite:////data/tablet_counter.db

# Zoho — self-hosted: route via integration service (transparent proxy layout)
ZOHO_SERVICE_BASE_URL=http://zoho-integration:9503
# Optional overrides if paths differ from Zoho’s defaults under the service:
# ZOHO_INVENTORY_API_BASE=
# ZOHO_TOKEN_URL=
# Optional JSON object merged into Zoho HTTP requests (e.g. internal API key):
# ZOHO_SERVICE_EXTRA_HEADERS={"X-Custom-Auth":"..."}

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# Behind nginx (container 104) / internal platform
BEHIND_PROXY=1
TRUSTED_PROXY_COUNT=1
# APPLICATION_ROOT=/tablet

# Request/query timing. Defaults on in development, off in production.
# PERF_LOGGING=0

# Command Center demo data toggle for local visual testing only.
# MES_COMMAND_CENTER_DEMO_MODE=0

# Shipping tracking integrations are optional. Leave blank to disable.
# UPS_CLIENT_ID=
# UPS_CLIENT_SECRET=
# UPS_API_BASE=https://apis.ups.com
# UPS_TRANSACTION_SRC=TabletTracker
# FEDEX_API_KEY=
# FEDEX_API_SECRET=
# FEDEX_ACCOUNT_NUMBER=
# FEDEX_BASE=https://apis.fedex.com

# Telegram bot integration is optional. TELEGRAM_ALLOWED_CHAT_IDS is required if enabled.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_PATH_SECRET=
# TELEGRAM_ALLOWED_CHAT_IDS=
# TELEGRAM_ALLOWED_USER_IDS=
# TELEGRAM_DAILY_REPORT_TIME=18:30

# PythonAnywhere / custom WSGI entrypoint option.
# TABLETTRACKER_ROOT=/home/yourusername/TabletTracker

# Tests/local tooling only: bypass self-hosted Zoho service enforcement.
# SKIP_ZOHO_SERVICE_CHECK=1
