# Copy to .env and fill in. Never commit .env.

FLASK_ENV=production
# Set automatically in the official Dockerfile; requires ZOHO_SERVICE_BASE_URL at runtime.
# TABLETTRACKER_SELF_HOSTED=1

SECRET_KEY=
ADMIN_PASSWORD=

# SQLite: default is database/tablet_counter.db. In Docker use a volume and e.g.:
# DATABASE_PATH=/data/tablet_counter.db
# DATABASE_URL=sqlite:////data/tablet_counter.db

# Zoho — self-hosted: route via integration service (transparent proxy layout)
ZOHO_SERVICE_BASE_URL=http://zoho-integration:9503
# Optional overrides if paths differ from Zoho’s defaults under the service:
# ZOHO_INVENTORY_API_BASE=
# ZOHO_TOKEN_URL=
# Optional JSON object merged into Zoho HTTP requests (e.g. internal API key):
# ZOHO_SERVICE_EXTRA_HEADERS={"X-Custom-Auth":"..."}

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=

# Behind nginx (container 104) / internal platform
BEHIND_PROXY=1
TRUSTED_PROXY_COUNT=1
# APPLICATION_ROOT=/tablet
